<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/_146sdp"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_6sdp"
    android:visibility="gone"
    android:background="@drawable/bg_transparent_ripple_square"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/catImage"
        android:layout_width="@dimen/_140sdp"
        android:layout_height="@dimen/_88sdp"
        android:src="@drawable/rp35"
        android:layout_margin="@dimen/_4sdp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_simple_btn_ripple"
        android:elevation="@dimen/_8sdp"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.8sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
    <TextView
        android:id="@+id/catName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/_4sdp"
        android:shadowDx="3"
        android:fontFamily="@font/raleway"
        android:shadowDy="3"
        android:text="@string/app_name"
        android:shadowColor="@color/black"
        android:shadowRadius="6"
        android:textAllCaps="true"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/catImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textSize="12sp"
        android:textColor="@color/clr_txt1" />

</androidx.constraintlayout.widget.ConstraintLayout>