<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@+id/iv_feature"
            android:layout_alignTop="@+id/iv_feature"
            android:layout_toStartOf="@+id/iv_feature"
            android:layout_toLeftOf="@+id/iv_feature"
            android:gravity="center_vertical"
            android:padding="5dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:lines="1"
                android:textColor="@android:color/black"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_short_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/tv_title"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/common_google_play_services_notification_ticker"
                android:textColor="#808080" />

        </RelativeLayout>

        <ImageView
            android:id="@+id/iv_feature"
            android:layout_width="@dimen/_70sdp"
            android:layout_height="@dimen/_55sdp"
            android:layout_alignParentEnd="true"
            android:adjustViewBounds="true"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/rp35" />

    </RelativeLayout>

</LinearLayout>