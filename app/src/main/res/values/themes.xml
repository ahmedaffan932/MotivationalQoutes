<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MotivationalQoutes" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/clr_dark_orange</item>
        <item name="colorPrimaryVariant">@color/clr_dark_orange</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/clr_dark_grey</item>

        <!-- Customize your theme here. -->
        <item name="fontFamily">@font/raleway</item>
    </style>

    <style name="splash_style" parent="Theme.AppCompat.NoActionBar">
<!--        <item name="android:windowFullscreen">true</item>-->
<!--        <item name="android:windowIsTranslucent">true</item>-->
<!--        <item name="android:windowBackground">@android:color/transparent</item>-->
<!--        <item name="android:windowContentOverlay">@null</item>-->
<!--        <item name="android:windowNoTitle">true</item>-->
<!--        <item name="android:windowIsFloating">false</item>-->
<!--        <item name="android:backgroundDimEnabled">true</item>-->
<!--        <item name="android:windowTranslucentNavigation">true</item>-->
    </style>

    <style name="ShapeAppearanceOverlay.App.8sdp" parent="">
        <item name="cornerSize">@dimen/_8sdp</item>
    </style>
    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="MineCustomTabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">@dimen/_11sdp</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="AdAttribution">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">left</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">6pt</item>
        <item name="android:text">Ad</item>
        <item name="android:background">@drawable/bg_simple_btn_ripple</item>
        <item name="android:backgroundTint">@color/black</item>
        <item name="android:width">@dimen/_24sdp</item>
        <item name="android:height">@dimen/_18sdp</item>
    </style>

    <style name="CustomBottomSheetDialog" parent="">
        <item name="android:background">@drawable/bg_mask_tl</item>
    </style>

</resources>